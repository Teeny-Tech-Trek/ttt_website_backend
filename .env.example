# ---- Server ----
PORT=5000
CORS_ORIGINS=https://www.teenytechtrek.com,http://localhost:5173,http://localhost:4173,http://localhost:3000

# ---- MongoDB (main backend DB: consultations, admins, etc.) ----
MONGO_URI=mongodb+srv://user:password@cluster0.example.mongodb.net/tttbackend

# ---- Admin auth (JWT) ----
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ---- SMTP (email notifications) ----
# Used for the consultation confirmation (to the user) and the owner alert.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASS=gmail_app_password
SMTP_FROM=example@gmail.com
OWNER_EMAIL=owner@example.com

# ---- Chatbot leads DB (read-only) ----
# The chatbot stores leads in its OWN cluster/database. The Admin CRM dashboard
# reads the `chatbot_leads` collection from here.
CHATBOT_MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/
CHATBOT_MONGO_DB=ttt_chatbot

# ---- Google Calendar (consultation booking) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.teenytechtrek.com/auth/google/callback
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
